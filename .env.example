# App environment
EXPO_PUBLIC_APP_ENV=development

# iOS bundle identifier override (optional)
IOS_BUNDLE_IDENTIFIER=com.rodrigojuarez.talkifymobile

# AdMob App IDs (required for native build config)
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~zzzzzzzzzz

# Rewarded Ad Unit IDs (used in play screen when free spins run out)
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_ID=ca-app-pub-xxxxxxxxxxxxxxxx/aaaaaaaaaa
EXPO_PUBLIC_ADMOB_REWARDED_IOS_ID=ca-app-pub-xxxxxxxxxxxxxxxx/bbbbbbbbbb

# Interstitial Ad Unit IDs (optional)
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=ca-app-pub-xxxxxxxxxxxxxxxx/cccccccccc
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=ca-app-pub-xxxxxxxxxxxxxxxx/dddddddddd
